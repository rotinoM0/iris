{
  "name": "iris-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Inventário, Registro e Integração de Sistemas",
  "keywords": [],
  "author": "Matheus Fernandes",
  "license": "Proprietary",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite dev",
    "build:win": "tsc -p . && vite build && electron-builder --win --config",
    "build:linux": "tsc -p . && vite build && electron-builder --linux --config",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "run-build": "vite build && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run start:electron\"",
    "start:electron": "wait-on tcp:5173 && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/vite": "^4.1.17",
    "axios": "^1.13.6",
    "dotenv": "^17.2.3",
    "electron-vite": "^4.0.1",
    "lucide-react": "^0.548.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.6.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@types/express": "^5.0.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^2.0.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^7.1.12",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.iris.system",
    "productName": "IRIS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": ""
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
